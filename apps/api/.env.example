# CyberGuard AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env files to version control.

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000

# Firebase — Full Mode (all three required for Firestore + Auth)
# Firebase — Auth-Only Mode (only projectId: verifyIdToken via Google public keys)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# JWT — Only used in legacy mode when Firebase is not configured
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-cryptographically-random-secret-at-least-32-bytes

# AI — OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Threat Intelligence — VirusTotal
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# Threat Intelligence — URLScan
URLSCAN_API_KEY=your-urlscan-api-key

# Threat Intelligence — AbuseIPDB
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# Alerts — Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
